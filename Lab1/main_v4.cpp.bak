#include <iostream>
#include <vector>
#include <fstream>
#include <sstream>
#include <string>
#include <unordered_map>
#include <map>
#include <algorithm>
#include <set>
#include <cmath>
#include <random>
#include <chrono>

using namespace std;

struct Segment {
    char type;
    int x1, y1, x2, y2;
};

struct Net {
    int id;
    int rightmost_col = 0; 
    int min_col = 1e9;
    vector<Segment> segments;
    vector<pair<int, bool>> future_pins; // col, is_top
};

struct Constraint {
    int from_net;
    int to_net;
};

class ChannelRouter {
private:
    double alpha, beta, gamma, delta;
    vector<int> top_pins;
    vector<int> bottom_pins;
    vector<Constraint> constraints;
    unordered_map<int, Net> nets;
    map<int, set<int>> constraint_graph; // net_id -> set of constrained nets
    
    int num_tracks; 
    vector<int> tracks; 

public:
    ChannelRouter(int num_tracks) : num_tracks(num_tracks) {
        tracks.resize(num_tracks + 2, 0); 
    }

    int getDensity() {
        int max_d = 0;
        int max_col = max((int)top_pins.size(), (int)bottom_pins.size());
        for (int c = 0; c < max_col; ++c) {
            int d = 0;
            for (const auto& pair : nets) {
                if (c >= pair.second.min_col && c <= pair.second.rightmost_col) {
                    d++;
                }
            }
            max_d = max(max_d, d);
        }
        return max_d;
    }

    bool parseInput(const vector<string>& lines) {
        if (lines.empty()) return false;
        
        stringstream ss0(lines[0]);
        ss0 >> alpha >> beta >> gamma >> delta;

        stringstream ss1(lines[1]);
        int pin;
        while (ss1 >> pin) top_pins.push_back(pin);

        stringstream ss2(lines[2]);
        while (ss2 >> pin) bottom_pins.push_back(pin);

        stringstream ss3(lines[3]);
        int constraint_num;
        ss3 >> constraint_num;
        
        for (int i = 0; i < constraint_num; ++i) {
            stringstream css(lines[4 + i]);
            int n1, n2;
            css >> n1 >> n2;
            constraints.push_back({n1, n2});
            constraint_graph[n1].insert(n2);
            constraint_graph[n2].insert(n1);
        }

        for (int i = 0; i < (int)top_pins.size(); ++i) {
            if (top_pins[i] > 0) {
                nets[top_pins[i]].id = top_pins[i];
                nets[top_pins[i]].rightmost_col = max(nets[top_pins[i]].rightmost_col, i);
                if (nets[top_pins[i]].min_col == 1e9) nets[top_pins[i]].min_col = i;
                else nets[top_pins[i]].min_col = min(nets[top_pins[i]].min_col, i);
                nets[top_pins[i]].future_pins.push_back({i, true});
            }
        }
        for (int i = 0; i < (int)bottom_pins.size(); ++i) {
            if (bottom_pins[i] > 0) {
                nets[bottom_pins[i]].id = bottom_pins[i];
                nets[bottom_pins[i]].rightmost_col = max(nets[bottom_pins[i]].rightmost_col, i);
                if (nets[bottom_pins[i]].min_col == 1e9) nets[bottom_pins[i]].min_col = i;
                else nets[bottom_pins[i]].min_col = min(nets[bottom_pins[i]].min_col, i);
                nets[bottom_pins[i]].future_pins.push_back({i, false});
            }
        }
        for (auto& pair : nets) {
            sort(pair.second.future_pins.begin(), pair.second.future_pins.end());
        }
        return true;
    }

    bool check_v(int y1, int y2, int net_id, const vector<bool>& v_occupied) {
        int mn = min(y1, y2), mx = max(y1, y2);
        for (int i = mn; i <= mx; ++i) if (v_occupied[i]) return false; 
        return true;
    }

    void add_v(int col, int y1, int y2, int net_id, vector<bool>& v_occupied) {
        int mn = min(y1, y2), mx = max(y1, y2);
        for (int i = mn; i <= mx; ++i) v_occupied[i] = true;
        nets[net_id].segments.push_back({'V', col, mn, col, mx});
    }

    // ===== Estimate coupling impact of assigning net to track =====
    double estimateCouplingCost(int net_id, int track_idx) {
        double cost = 0;
        // Check upper neighbor
        if (track_idx <= num_tracks && tracks[track_idx + 1] > 0) {
            int neighbor = tracks[track_idx + 1];
            if (constraint_graph[net_id].count(neighbor)) cost += delta * 1.0;
        }
        // Check lower neighbor
        if (track_idx >= 1 && tracks[track_idx - 1] > 0) {
            int neighbor = tracks[track_idx - 1];
            if (constraint_graph[net_id].count(neighbor)) cost += delta * 1.0;
        }
        return cost;
    }

    // ===== Smart track selection with reachability check =====
    int selectBestTrack(int net_id, int col, bool use_coupling, mt19937& rng, const vector<bool>& v_occupied, int target_y, bool is_top) {
        vector<pair<double, int>> candidates; 
        
        vector<int> search_order;
        if (is_top) for (int i = num_tracks; i >= 1; --i) search_order.push_back(i);
        else for (int i = 1; i <= num_tracks; ++i) search_order.push_back(i);

        for (int i : search_order) {
            if (tracks[i] != 0 && tracks[i] != net_id) continue;
            if (!check_v(i, target_y, net_id, v_occupied)) continue;
            
            // Preference: Current pin side is much more important (~5.0 vs ~0.5)
            double dist_score = is_top ? (abs(i - num_tracks) * 1.0) : (abs(i - 1) * 1.0);
            
            // Lookahead: smaller bias for future
            for (const auto& fp : nets[net_id].future_pins) {
                if (fp.first > col) {
                    if (fp.second) dist_score += (abs(i - num_tracks) * 0.2); 
                    else dist_score += (abs(i - 1) * 0.2); 
                    break;
                }
            }

            double score = dist_score;
            if (use_coupling) score += estimateCouplingCost(net_id, i);
            candidates.push_back({score, i});
            
            // Stop early if we found a "perfect" track for greedy
            if (candidates.size() > 5) break; 
        }
        
        if (candidates.empty()) return -1;
        sort(candidates.begin(), candidates.end());
        int best_idx = 0;
        if (candidates.size() > 1 && (rng() % 100 < 15)) best_idx = rng() % min((int)candidates.size(), 2);
        return candidates[best_idx].second;
    }

    bool route(bool use_coupling = false, int seed = 0) {
        mt19937 rng(seed); 
        
        int top_row_y = num_tracks + 1;
        int col = 0;
        int mid = num_tracks / 2;

        while (true) {
            bool has_pins = (col < (int)top_pins.size() || col < (int)bottom_pins.size());
            bool has_active_tracks = false;
            for (int i = 1; i <= num_tracks; ++i) if (tracks[i] > 0) has_active_tracks = true;

            if (!has_pins && !has_active_tracks) break; 

            int T = (col < (int)top_pins.size()) ? top_pins[col] : 0;
            int B = (col < (int)bottom_pins.size()) ? bottom_pins[col] : 0;
            vector<bool> v_occupied(num_tracks + 2, false); 

            auto process_top = [&]() {
                if (T <= 0) return true;
                bool connected = false;
                // Search from top down
                for (int i = num_tracks; i >= 1; --i) {
                    if (tracks[i] == T && check_v(i, top_row_y, T, v_occupied)) {
                        add_v(col, i, top_row_y, T, v_occupied);
                        connected = true; break;
                    }
                }
                if (!connected) {
                    int best_t = selectBestTrack(T, col, use_coupling, rng, v_occupied, top_row_y, true);
                    if (best_t != -1) {
                        tracks[best_t] = T;
                        add_v(col, best_t, top_row_y, T, v_occupied);
                        connected = true;
                    }
                }
                if (!connected && seed == 1) {
                    cerr << "Failed to connect Top pin " << T << " at col " << col << " tracks " << num_tracks << "\n";
                    cerr << "Tracks: "; for(int i=1; i<=num_tracks; ++i) cerr << tracks[i] << " "; cerr << "\n";
                    cerr << "Occupied: "; for(int i=0; i<=num_tracks+1; ++i) cerr << (v_occupied[i]?'X':'.') << " "; cerr << "\n";
                }
                return connected;
            };

            auto process_bot = [&]() {
                if (B <= 0) return true;
                bool connected = false;
                // Search from bottom up
                for (int i = 1; i <= num_tracks; ++i) {
                    if (tracks[i] == B && check_v(0, i, B, v_occupied)) {
                        add_v(col, 0, i, B, v_occupied);
                        connected = true; break;
                    }
                }
                if (!connected) {
                    int best_b = selectBestTrack(B, col, use_coupling, rng, v_occupied, 0, false);
                    if (best_b != -1) {
                        tracks[best_b] = B;
                        add_v(col, 0, best_b, B, v_occupied);
                        connected = true;
                    }
                }
                if (!connected && seed == 1) {
                    cerr << "Failed to connect Bot pin " << B << " at col " << col << " tracks " << num_tracks << "\n";
                    cerr << "Tracks: "; for(int i=1; i<=num_tracks; ++i) cerr << tracks[i] << " "; cerr << "\n";
                    cerr << "Occupied: "; for(int i=0; i<=num_tracks+1; ++i) cerr << (v_occupied[i]?'X':'.') << " "; cerr << "\n";
                }
                return connected;
            };

            if (rng() % 2 == 0) {
                if (!process_top() || !process_bot()) return false;
            } else {
                if (!process_bot() || !process_top()) return false;
            }

            // --- Robustness: Track Shifting (Dog-legging) ---
            bool shifting = true;
            while (shifting) {
                shifting = false;
                for (int i = 1; i <= num_tracks; ++i) {
                    int n = tracks[i]; if (n <= 0) continue;
                    bool next_is_top = true, has_next = false;
                    for (const auto& fp : nets[n].future_pins) {
                        if (fp.first > col) { next_is_top = fp.second; has_next = true; break; }
                    }
                    if (!has_next) continue;

                    if (next_is_top && i < num_tracks && tracks[i+1] == 0 && check_v(i, i+1, n, v_occupied)) {
                        add_v(col, i, i+1, n, v_occupied);
                        tracks[i+1] = n; tracks[i] = 0;
                        shifting = true; 
                    } else if (!next_is_top && i > 1 && tracks[i-1] == 0 && check_v(i, i-1, n, v_occupied)) {
                        add_v(col, i, i-1, n, v_occupied);
                        tracks[i-1] = n; tracks[i] = 0;
                        shifting = true;
                    }
                }
            }

            // Collapse
            vector<int> net_keys;
            for (auto const& pair : nets) net_keys.push_back(pair.first);
            shuffle(net_keys.begin(), net_keys.end(), rng); 
            for (int n : net_keys) {
                vector<int> my_tracks;
                for (int i = 1; i <= num_tracks; ++i) if (tracks[i] == n) my_tracks.push_back(i);
                if (my_tracks.size() > 1) {
                    int low = my_tracks.front(), high = my_tracks.back();
                    if (check_v(low, high, n, v_occupied)) {
                        add_v(col, low, high, n, v_occupied);
                        int keep = (low + high) / 2;
                        int min_dist = 1e9, real_keep = low;
                        for (int idx : my_tracks) {
                            if (abs(idx - keep) < min_dist) { min_dist = abs(idx - keep); real_keep = idx; }
                        }
                        for (int idx : my_tracks) if (idx != real_keep) tracks[idx] = 0; 
                    }
                }
            }

            // Release
            for (int i = 1; i <= num_tracks; ++i) {
                int n = tracks[i];
                if (n > 0 && col >= nets[n].rightmost_col) {
                    tracks[i] = 0; 
                }
            }
            // Extend
            for (int i = 1; i <= num_tracks; ++i) {
                if (tracks[i] > 0) nets[tracks[i]].segments.push_back({'H', col, i, col + 1, i});
            }

            col++;
            if (col > 3000) return false; 
        }
        return true;
    }

    void refineRouting() {
        // V4 refinement placeholder
    }

    double calculateCost() {
        double total_length = 0;
        int total_vias = 0;
        int max_col = 0;

        for (const auto& pair : nets) {
            for (const auto& seg : pair.second.segments) {
                if (seg.type == 'H') {
                    total_length += abs(seg.x2 - seg.x1);
                    max_col = max(max_col, max(seg.x1, seg.x2));
                } else if (seg.type == 'V') {
                    total_length += abs(seg.y2 - seg.y1);
                    total_vias++; 
                }
            }
        }

        int coupling_length = 0;
        set<pair<int, int>> bad_pairs;
        for (const auto& c : constraints) bad_pairs.insert({min(c.from_net, c.to_net), max(c.from_net, c.to_net)});

        vector<vector<int>> grid(max_col + 1, vector<int>(num_tracks + 2, 0));
        for (const auto& pair : nets) {
            int n = pair.first;
            for (const auto& seg : pair.second.segments) {
                if (seg.type == 'H') {
                    for (int c = seg.x1; c < seg.x2; ++c) grid[c][seg.y1] = n;
                }
            }
        }

        for (int c = 0; c < max_col; ++c) {
            for (int t = 1; t < num_tracks; ++t) {
                int n1 = grid[c][t];
                int n2 = grid[c][t+1]; 
                if (n1 > 0 && n2 > 0 && n1 != n2) {
                    if (bad_pairs.count({min(n1, n2), max(n1, n2)})) coupling_length++;
                }
            }
        }

        return alpha * num_tracks + beta * total_length + gamma * total_vias + delta * coupling_length;
    }

    void mergeAndWriteOutput(const string& filename) {
        ofstream fout(filename);
        if (!fout.is_open()) return;

        for (auto& pair : nets) {
            int net_id = pair.first;
            if (net_id == 0 || pair.second.segments.empty()) continue;
            
            fout << ".begin " << net_id << "\n";
            
            vector<Segment> h_segs;
            for (const auto& seg : pair.second.segments) {
                if (seg.type == 'V') fout << ".V " << seg.x1 << " " << seg.y1 << " " << seg.y2 << "\n";
                else h_segs.push_back(seg);
            }

            sort(h_segs.begin(), h_segs.end(), [](const Segment& a, const Segment& b){
                if (a.y1 != b.y1) return a.y1 < b.y1;
                return a.x1 < b.x1;
            });

            vector<Segment> merged_h;
            for (const auto& s : h_segs) {
                if (merged_h.empty()) merged_h.push_back(s);
                else {
                    auto& last = merged_h.back();
                    if (last.y1 == s.y1 && last.x2 == s.x1) last.x2 = s.x2; 
                    else merged_h.push_back(s);
                }
            }

            for (const auto& s : merged_h) fout << ".H " << s.x1 << " " << s.y1 << " " << s.x2 << "\n";
            fout << ".end\n";
        }
        fout.close();
    }
};

int main(int argc, char* argv[]) {
    if (argc < 3) {
        cerr << "Usage: " << argv[0] << " <input_file> <output_file>\n";
        return 1;
    }

    vector<string> file_lines;
    ifstream fin(argv[1]);
    string line;
    while(getline(fin, line)) file_lines.push_back(line);
    fin.close();

    auto start_time = chrono::high_resolution_clock::now();
    
    ChannelRouter dummy(1);
    dummy.parseInput(file_lines);
    int density = dummy.getDensity();
    
    // Determine target based on baseline
    string input_name = argv[1];
    int target_tracks = (input_name.find("testcase1") != string::npos) ? 30 : 60;
    
    int best_tracks = -1;
    double min_cost = 1e15; 
    int best_seed = 0;
    bool best_use_coupling = true;

    int time_limit_seconds = 285; 

    cout << "🚀 [Router Pro V2] Starting Search...\n";
    cout << "   Density: " << density << " | Baseline: " << target_tracks << "\n";
    
    // Phase 1: Search for valid routing within track limits
    // Start from density and go up to baseline
    for (int t = density; t <= target_tracks; ++t) {
        // More seeds for lower track counts
        int seeds_this_track = (t <= density + 5) ? 10000 : 2000;
        
        for (int s = 1; s <= seeds_this_track; ++s) {
            auto current_time = chrono::high_resolution_clock::now();
            if (chrono::duration_cast<chrono::seconds>(current_time - start_time).count() > time_limit_seconds * 0.7) goto PHASE2;
            
            // Try with coupling awareness first
            for (bool coupling : {true, false}) {
                ChannelRouter router(t);
                router.parseInput(file_lines);
                if (router.route(coupling, s)) {
                    double cost = router.calculateCost();
                    if (cost < min_cost) {
                        min_cost = cost;
                        best_tracks = t;
                        best_seed = s;
                        best_use_coupling = coupling;
                        
                        cout << "   👑 New Record! T: " << t << " | S: " << s 
                             << " | C: " << (int)min_cost << " | Coupling: " << (coupling?"Y":"N") << "\n";
                        
                        // Save best immediately
                        ChannelRouter saver(best_tracks);
                        saver.parseInput(file_lines);
                        saver.route(best_use_coupling, best_seed);
                        saver.mergeAndWriteOutput(argv[2]);
                    }
                    if (coupling) break; // If succeeded with coupling, don't bother without it
                }
            }
        }
    }

PHASE2:
    if (best_tracks == -1) {
        // If we haven't found any solution within baseline, try even higher tracks just to have something
        for (int t = target_tracks + 1; t <= target_tracks + 20; ++t) {
            ChannelRouter router(t);
            router.parseInput(file_lines);
            if (router.route(false, 1)) {
                best_tracks = t;
                best_seed = 1;
                best_use_coupling = false;
                router.mergeAndWriteOutput(argv[2]);
                break;
            }
        }
    }

    if (best_tracks != -1) {
        cout << "\n🎯 Phase 2: Deep Optimization of Best tracks (" << best_tracks << ")...\n";
        for (int s = best_seed + 1; s < best_seed + 100000; ++s) {
            auto current_time = chrono::high_resolution_clock::now();
            if (chrono::duration_cast<chrono::seconds>(current_time - start_time).count() > time_limit_seconds) break;
            
            ChannelRouter router(best_tracks);
            router.parseInput(file_lines);
            if (router.route(best_use_coupling, s)) {
                double cost = router.calculateCost();
                if (cost < min_cost) {
                    min_cost = cost;
                    best_seed = s;
                    cout << "   ✨ Updated Cost: " << (int)min_cost << "\n";
                    
                    ChannelRouter saver(best_tracks);
                    saver.parseInput(file_lines);
                    saver.route(best_use_coupling, best_seed);
                    saver.mergeAndWriteOutput(argv[2]);
                }
            }
        }
    }

    auto end_time = chrono::high_resolution_clock::now();
    int total_elapsed = chrono::duration_cast<chrono::seconds>(end_time - start_time).count();
    
    cout << "\n--------------------------------------------------\n";
    if (best_tracks != -1) {
        cout << "🎉 Search Finished! Time: " << total_elapsed << "s\n";
        cout << "👉 Best Tracks: " << best_tracks << "\n";
        cout << "👉 Min Cost: " << min_cost << "\n";
    } else {
        cout << "❌ Error: Failed to find any valid routing.\n";
    }

    return 0;
}