#include <iostream>
#include <vector>
#include <fstream>
#include <sstream>
#include <string>
#include <unordered_map>
#include <map>
#include <algorithm>
#include <set>
#include <cmath>
#include <random>
#include <chrono>
#include <queue>

using namespace std;

struct Segment {
    char type;
    int x1, y1, x2, y2;
};

struct Net {
    int id;
    int rightmost_col;
    vector<Segment> segments;
};

struct Constraint {
    int from_net;
    int to_net;
};

class UnionFind {
public:
    vector<int> parent, rank;
    
    UnionFind(int n) : parent(n), rank(n, 0) {
        iota(parent.begin(), parent.end(), 0);
    }
    
    int find(int x) {
        if (parent[x] != x) parent[x] = find(parent[x]);
        return parent[x];
    }
    
    void unite(int x, int y) {
        x = find(x); y = find(y);
        if (x == y) return;
        if (rank[x] < rank[y]) swap(x, y);
        parent[y] = x;
        if (rank[x] == rank[y]) rank[x]++;
    }
};

class ChannelRouter {
private:
    double alpha, beta, gamma, delta;
    vector<int> top_pins;
    vector<int> bottom_pins;
    vector<Constraint> constraints;
    unordered_map<int, Net> nets;
    map<int, set<int>> constraint_graph; // net_id -> set of constrained nets
    
    int num_tracks;
    vector<int> tracks;
    
public:
    ChannelRouter(int num_tracks) : num_tracks(num_tracks) {
        tracks.resize(num_tracks + 2, 0);
    }

    bool parseInput(const vector<string>& lines) {
        if (lines.empty()) return false;
        
        stringstream ss0(lines[0]);
        ss0 >> alpha >> beta >> gamma >> delta;

        stringstream ss1(lines[1]);
        int pin;
        while (ss1 >> pin) top_pins.push_back(pin);

        stringstream ss2(lines[2]);
        while (ss2 >> pin) bottom_pins.push_back(pin);

        stringstream ss3(lines[3]);
        int constraint_num;
        ss3 >> constraint_num;
        
        for (int i = 0; i < constraint_num; ++i) {
            stringstream css(lines[4 + i]);
            int n1, n2;
            css >> n1 >> n2;
            constraints.push_back({n1, n2});
            constraint_graph[n1].insert(n2);
            constraint_graph[n2].insert(n1);
        }

        // Preprocess: find rightmost column for each net
        for (int i = 0; i < top_pins.size(); ++i) {
            if (top_pins[i] > 0) nets[top_pins[i]].rightmost_col = max(nets[top_pins[i]].rightmost_col, i);
        }
        for (int i = 0; i < bottom_pins.size(); ++i) {
            if (bottom_pins[i] > 0) nets[bottom_pins[i]].rightmost_col = max(nets[bottom_pins[i]].rightmost_col, i);
        }
        
        return true;
    }

    // ===== Build Constraint Groups =====
    vector<set<int>> getConstraintGroups() {
        map<int, set<int>> constraint_map;
        for (const auto& c : constraints) {
            constraint_map[c.from_net].insert(c.to_net);
            constraint_map[c.to_net].insert(c.from_net);
        }
        
        set<int> all_nets;
        for (const auto& [net_id, _] : nets) {
            if (net_id > 0) all_nets.insert(net_id);
        }
        
        // Union-find to group constrained nets
        UnionFind uf(100000);
        for (const auto& c : constraints) {
            uf.unite(c.from_net, c.to_net);
        }
        
        map<int, set<int>> groups;
        for (int net_id : all_nets) {
            groups[uf.find(net_id)].insert(net_id);
        }
        
        vector<set<int>> result;
        for (const auto& [root, group] : groups) {
            result.push_back(group);
        }
        
        // Sort by group size (smaller = higher priority)
        sort(result.begin(), result.end(), [](const auto& a, const auto& b) {
            return a.size() < b.size();
        });
        
        return result;
    }

    bool check_v(int y1, int y2, int net_id, const vector<bool>& v_occupied) {
        int mn = min(y1, y2), mx = max(y1, y2);
        for (int i = mn; i <= mx; ++i) if (v_occupied[i]) return false;
        return true;
    }

    void add_v(int col, int y1, int y2, int net_id, vector<bool>& v_occupied) {
        int mn = min(y1, y2), mx = max(y1, y2);
        for (int i = mn; i <= mx; ++i) v_occupied[i] = true;
        nets[net_id].segments.push_back({'V', col, mn, col, mx});
    }

    // ===== Estimate coupling impact of assigning net to track =====
    double estimateCouplingCost(int net_id, int track_idx, const vector<int>& current_tracks) {
        double cost = 0;
        
        // Check upper neighbor
        if (track_idx < num_tracks && current_tracks[track_idx + 1] > 0) {
            int neighbor = current_tracks[track_idx + 1];
            // Penalty if neighbor is constrained
            if (constraint_graph[net_id].count(neighbor)) {
                cost += delta * 10; // High penalty for adjacent constrained nets
            }
        }
        
        // Check lower neighbor
        if (track_idx > 1 && current_tracks[track_idx - 1] > 0) {
            int neighbor = current_tracks[track_idx - 1];
            if (constraint_graph[net_id].count(neighbor)) {
                cost += delta * 10;
            }
        }
        
        return cost;
    }

    // ===== Smart track selection with coupling prediction =====
    int selectBestTrack(int net_id, int col, const vector<int>& current_tracks, 
                        bool prefer_constraint_satisfaction, mt19937& rng) {
        int top_row_y = num_tracks + 1;
        int mid = num_tracks / 2;
        
        set<pair<int, int>> bad_pairs;
        for (const auto& c : constraints) {
            bad_pairs.insert({min(c.from_net, c.to_net), max(c.from_net, c.to_net)});
        }
        
        auto is_conflict = [&](int n1, int n2) {
            if (n1 <= 0 || n2 <= 0 || n1 == n2) return false;
            return bad_pairs.count({min(n1, n2), max(n1, n2)}) > 0;
        };
        
        vector<pair<double, int>> candidates; // (cost, track)
        
        // Evaluate each candidate track
        for (int i = 1; i <= num_tracks; ++i) {
            bool track_available = (current_tracks[i] == 0 || current_tracks[i] == net_id);
            if (!track_available) continue;
            
            double score = 0;
            
            // Give points for distance from middle
            score -= abs(i - mid) * 0.5;
            
            // Heavy penalty for neighbor conflicts
            if (current_tracks[i-1] > 0 && is_conflict(net_id, current_tracks[i-1])) {
                score += 1000;
            }
            if (current_tracks[i+1] > 0 && is_conflict(net_id, current_tracks[i+1])) {
                score += 1000;
            }
            
            // Coupling penalty
            score += estimateCouplingCost(net_id, i, current_tracks);
            
            candidates.push_back({score, i});
        }
        
        if (candidates.empty()) return -1;
        
        // Sort by score and pick best (or random from top candidates)
        sort(candidates.begin(), candidates.end());
        int best_idx = (candidates.size() > 0) ? candidates[0].second : -1;
        
        return best_idx;
    }

    bool route(int seed = 0) {
        mt19937 rng(seed);
        
        int top_row_y = num_tracks + 1;
        int col = 0;
        int mid = num_tracks / 2;

        set<pair<int, int>> bad_pairs;
        for (const auto& c : constraints) {
            bad_pairs.insert({min(c.from_net, c.to_net), max(c.from_net, c.to_net)});
        }

        auto is_conflict = [&](int n1, int n2) {
            if (n1 <= 0 || n2 <= 0 || n1 == n2) return false;
            return bad_pairs.count({min(n1, n2), max(n1, n2)}) > 0;
        };

        while (true) {
            bool has_pins = (col < (int)top_pins.size() || col < (int)bottom_pins.size());
            bool has_active_tracks = false;
            for (int i = 1; i <= num_tracks; ++i) if (tracks[i] > 0) has_active_tracks = true;

            if (!has_pins && !has_active_tracks) break;

            int T = (col < (int)top_pins.size()) ? top_pins[col] : 0;
            int B = (col < (int)bottom_pins.size()) ? bottom_pins[col] : 0;
            vector<bool> v_occupied(num_tracks + 2, false);

            // Process top pin using smart track selection
            if (T > 0) {
                bool connected = false;
                
                // Try to reuse existing track
                for (int i = 1; i <= num_tracks; ++i) {
                    if (tracks[i] == T && check_v(i, top_row_y, T, v_occupied)
                        && (!is_conflict(T, tracks[i-1]) && !is_conflict(T, tracks[i+1]))) {
                        add_v(col, i, top_row_y, T, v_occupied);
                        connected = true;
                        break;
                    }
                }
                
                // Assign new track using smart selection
                if (!connected) {
                    int best_track = selectBestTrack(T, col, tracks, true, rng);
                    if (best_track != -1 && check_v(best_track, top_row_y, T, v_occupied)) {
                        tracks[best_track] = T;
                        add_v(col, best_track, top_row_y, T, v_occupied);
                        connected = true;
                    }
                }
                
                if (!connected) return false;
            }

            // Process bottom pin
            if (B > 0) {
                bool connected = false;
                
                for (int i = 1; i <= num_tracks; ++i) {
                    if (tracks[i] == B && check_v(0, i, B, v_occupied)
                        && (!is_conflict(B, tracks[i-1]) && !is_conflict(B, tracks[i+1]))) {
                        add_v(col, 0, i, B, v_occupied);
                        connected = true;
                        break;
                    }
                }
                
                if (!connected) {
                    int best_track = selectBestTrack(B, col, tracks, true, rng);
                    if (best_track != -1 && check_v(0, best_track, B, v_occupied)) {
                        tracks[best_track] = B;
                        add_v(col, 0, best_track, B, v_occupied);
                        connected = true;
                    }
                }
                
                if (!connected) return false;
            }

            // Collapse multi-track nets
            for (auto const& pair : nets) {
                int n = pair.first;
                vector<int> my_tracks;
                for (int i = 1; i <= num_tracks; ++i) if (tracks[i] == n) my_tracks.push_back(i);
                
                if (my_tracks.size() > 1) {
                    int low = my_tracks.front(), high = my_tracks.back();
                    if (check_v(low, high, n, v_occupied)) {
                        add_v(col, low, high, n, v_occupied);
                        int keep = low;
                        int min_dist = abs(low - mid);
                        for (int idx : my_tracks) {
                            if (abs(idx - mid) < min_dist) { min_dist = abs(idx - mid); keep = idx; }
                        }
                        for (int idx : my_tracks) if (idx != keep) tracks[idx] = 0;
                    }
                }
            }

            // Extend horizontal
            for (int i = 1; i <= num_tracks; ++i) {
                if (tracks[i] > 0) nets[tracks[i]].segments.push_back({'H', col, i, col + 1, i});
            }
            
            col++;
        }
        
        return true;
    }

    double calculateCost() {
        double total_length = 0;
        int total_vias = 0;
        int max_col = 0;

        for (const auto& pair : nets) {
            for (const auto& seg : pair.second.segments) {
                if (seg.type == 'H') {
                    total_length += abs(seg.x2 - seg.x1);
                    max_col = max(max_col, max(seg.x1, seg.x2));
                } else if (seg.type == 'V') {
                    total_length += abs(seg.y2 - seg.y1);
                    total_vias++;
                }
            }
        }

        int coupling_length = 0;
        set<pair<int, int>> bad_pairs;
        for (const auto& c : constraints) bad_pairs.insert({min(c.from_net, c.to_net), max(c.from_net, c.to_net)});

        vector<vector<int>> grid(max_col + 1, vector<int>(num_tracks + 2, 0));
        for (const auto& pair : nets) {
            int n = pair.first;
            for (const auto& seg : pair.second.segments) {
                if (seg.type == 'H') {
                    for (int c = seg.x1; c < seg.x2; ++c) grid[c][seg.y1] = n;
                }
            }
        }

        for (int c = 0; c < max_col; ++c) {
            for (int t = 1; t < num_tracks; ++t) {
                int n1 = grid[c][t];
                int n2 = grid[c][t+1];
                if (n1 > 0 && n2 > 0 && n1 != n2) {
                    if (bad_pairs.count({min(n1, n2), max(n1, n2)})) coupling_length++;
                }
            }
        }

        return alpha * num_tracks + beta * total_length + gamma * total_vias + delta * coupling_length;
    }

    void mergeAndWriteOutput(const string& filename) {
        ofstream fout(filename);
        if (!fout.is_open()) return;

        for (auto& pair : nets) {
            int net_id = pair.first;
            if (net_id == 0 || pair.second.segments.empty()) continue;
            
            fout << ".begin " << net_id << "\n";
            
            vector<Segment> h_segs;
            for (const auto& seg : pair.second.segments) {
                if (seg.type == 'V') fout << ".V " << seg.x1 << " " << seg.y1 << " " << seg.y2 << "\n";
                else h_segs.push_back(seg);
            }

            sort(h_segs.begin(), h_segs.end(), [](const Segment& a, const Segment& b){
                if (a.y1 != b.y1) return a.y1 < b.y1;
                return a.x1 < b.x1;
            });

            vector<Segment> merged_h;
            for (const auto& s : h_segs) {
                if (merged_h.empty()) merged_h.push_back(s);
                else {
                    auto& last = merged_h.back();
                    if (last.y1 == s.y1 && last.x2 == s.x1) last.x2 = s.x2;
                    else merged_h.push_back(s);
                }
            }

            for (const auto& s : merged_h) fout << ".H " << s.x1 << " " << s.y1 << " " << s.x2 << "\n";
            fout << ".end\n";
        }
        fout.close();
    }
};

int main(int argc, char* argv[]) {
    if (argc < 3) {
        cerr << "Usage: " << argv[0] << " <input_file> <output_file>\n";
        return 1;
    }

    vector<string> file_lines;
    ifstream fin(argv[1]);
    string line;
    while(getline(fin, line)) file_lines.push_back(line);
    fin.close();

    auto start_time = chrono::high_resolution_clock::now();

    int best_tracks = -1;
    double min_cost = 1e15;
    int best_seed = 0;

    int max_search_tracks = 32;
    int time_limit = 280;

    cout << "🚀 [V2: 約束感知路由] 啟動！\n";
    cout << "    策略：約束圖分析 + 耦合預估 + 貪心軌道選擇\n\n";

    // Phase 1: Quick exploration
    for (int tracks = 25; tracks <= max_search_tracks; ++tracks) {
        int max_seeds = (tracks <= 28) ? 8000 : 3000;

        for (int seed = 1; seed <= max_seeds; ++seed) {
            auto now = chrono::high_resolution_clock::now();
            if (chrono::duration_cast<chrono::seconds>(now - start_time).count() > time_limit * 0.7) {
                goto PHASE2;
            }

            ChannelRouter router(tracks);
            router.parseInput(file_lines);
            
            if (router.route(seed)) {
                double cost = router.calculateCost();
                
                if (cost < min_cost) {
                    min_cost = cost;
                    best_tracks = tracks;
                    best_seed = seed;
                    
                    cout << "✨ 新紀錄！ Tracks: " << tracks << " | Seed: " << seed
                         << " | Cost: " << min_cost << "\n";
                    
                    ChannelRouter tmp(best_tracks);
                    tmp.parseInput(file_lines);
                    tmp.route(best_seed);
                    tmp.mergeAndWriteOutput(argv[2]);
                }
            }
        }
    }

PHASE2:
    // Phase 2: Deep refinement
    cout << "\n🎯 Phase 2: 深度優化...\n";
    if (best_tracks != -1) {
        for (int seed = best_seed + 1; seed <= best_seed + 60000; ++seed) {
            auto now = chrono::high_resolution_clock::now();
            if (chrono::duration_cast<chrono::seconds>(now - start_time).count() > time_limit) {
                goto END;
            }

            ChannelRouter router(best_tracks);
            router.parseInput(file_lines);
            
            if (router.route(seed)) {
                double cost = router.calculateCost();
                
                if (cost < min_cost) {
                    min_cost = cost;
                    best_seed = seed;
                    
                    cout << "✨ 更新！ Cost: " << min_cost << "\n";
                    
                    ChannelRouter tmp(best_tracks);
                    tmp.parseInput(file_lines);
                    tmp.route(best_seed);
                    tmp.mergeAndWriteOutput(argv[2]);
                }
            }
        }
    }

END:
    auto end_time = chrono::high_resolution_clock::now();
    int elapsed = chrono::duration_cast<chrono::seconds>(end_time - start_time).count();

    cout << "\n✅ 搜尋完成！耗時 " << elapsed << " 秒\n";
    cout << "📊 最佳結果: " << best_tracks << " 軌, 成本 " << min_cost << "\n";

    return 0;
}
