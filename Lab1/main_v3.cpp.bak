#include <iostream>
#include <vector>
#include <fstream>
#include <sstream>
#include <string>
#include <unordered_map>
#include <map>
#include <algorithm>
#include <set>
#include <cmath>
#include <random>
#include <chrono>

using namespace std;

struct Segment {
    char type;
    int x1, y1, x2, y2;
};

struct Net {
    int id;
    int rightmost_col;
    vector<Segment> segments;
};

struct Constraint {
    int from_net;
    int to_net;
};

class ChannelRouter {
private:
    double alpha, beta, gamma, delta;
    vector<int> top_pins;
    vector<int> bottom_pins;
    vector<Constraint> constraints;
    unordered_map<int, Net> nets;
    
    int num_tracks;
    vector<int> tracks;
    
public:
    ChannelRouter(int num_tracks) : num_tracks(num_tracks) {
        tracks.resize(num_tracks + 2, 0);
    }

    bool parseInput(const vector<string>& lines) {
        if (lines.empty()) return false;
        
        stringstream ss0(lines[0]);
        ss0 >> alpha >> beta >> gamma >> delta;

        stringstream ss1(lines[1]);
        int pin;
        while (ss1 >> pin) top_pins.push_back(pin);

        stringstream ss2(lines[2]);
        while (ss2 >> pin) bottom_pins.push_back(pin);

        stringstream ss3(lines[3]);
        int constraint_num;
        ss3 >> constraint_num;
        
        for (int i = 0; i < constraint_num; ++i) {
            stringstream css(lines[4 + i]);
            int n1, n2;
            css >> n1 >> n2;
            constraints.push_back({n1, n2});
        }

        // Preprocess: find rightmost column for each net
        for (int i = 0; i < top_pins.size(); ++i) {
            if (top_pins[i] > 0) nets[top_pins[i]].rightmost_col = max(nets[top_pins[i]].rightmost_col, i);
        }
        for (int i = 0; i < bottom_pins.size(); ++i) {
            if (bottom_pins[i] > 0) nets[bottom_pins[i]].rightmost_col = max(nets[bottom_pins[i]].rightmost_col, i);
        }
        
        return true;
    }

    // ===== Intelligent Seed Generator =====
    // Generate seeds that are variations of pin positions
    vector<int> generateIntelligentSeeds(int base_count) {
        vector<int> seeds;
        set<int> seed_set;
        
        // Add seeds based on pin column positions
        for (int col : top_pins) {
            if (col > 0) seed_set.insert((col * 31) ^ 0x9e3779b9);
        }
        for (int col : bottom_pins) {
            if (col > 0) seed_set.insert((col * 37) ^ 0x9e3779b9);
        }
        
        // Add seeds based on constraint patterns
        for (const auto& c : constraints) {
            int combined = (c.from_net * 41 + c.to_net) ^ 0x9e3779b9;
            seed_set.insert(abs(combined));
        }
        
        // Add random seeds
        mt19937 gen(chrono::system_clock::now().time_since_epoch().count());
        for (int i = 0; i < base_count; ++i) {
            seed_set.insert(gen());
        }
        
        seeds.assign(seed_set.begin(), seed_set.end());
        return seeds;
    }

    bool check_v(int y1, int y2, int net_id, const vector<bool>& v_occupied) {
        int mn = min(y1, y2), mx = max(y1, y2);
        for (int i = mn; i <= mx; ++i) if (v_occupied[i]) return false;
        return true;
    }

    void add_v(int col, int y1, int y2, int net_id, vector<bool>& v_occupied) {
        int mn = min(y1, y2), mx = max(y1, y2);
        for (int i = mn; i <= mx; ++i) v_occupied[i] = true;
        nets[net_id].segments.push_back({'V', col, mn, col, mx});
    }

    // ===== Coupling-aware collapse =====
    void collapseTracksWithCouplingAware(int col, vector<bool>& v_occupied, 
                                         const set<pair<int,int>>& bad_pairs) {
        int mid = num_tracks / 2;
        
        for (auto const& pair : nets) {
            int n = pair.first;
            vector<int> my_tracks;
            for (int i = 1; i <= num_tracks; ++i) if (tracks[i] == n) my_tracks.push_back(i);
            
            if (my_tracks.size() > 1) {
                // Try to collapse with coupling awareness
                int low = my_tracks.front(), high = my_tracks.back();
                
                // Check via cost
                double via_cost = abs(high - low) * gamma;
                
                // Estimate spillover reduction
                int track_pressure = 0;
                for (int i = 1; i <= num_tracks; ++i) if (tracks[i] > 0) track_pressure++;
                double spillover_reduction = (track_pressure > num_tracks * 0.8) ? alpha * 5 : 0;
                
                // If beneficial, collapse
                if (via_cost < spillover_reduction && check_v(low, high, n, v_occupied)) {
                    add_v(col, low, high, n, v_occupied);
                    
                    // Keep track nearest to middle
                    int keep = low;
                    int min_dist = abs(low - mid);
                    for (int idx : my_tracks) {
                        if (abs(idx - mid) < min_dist) { 
                            min_dist = abs(idx - mid); 
                            keep = idx; 
                        }
                    }
                    
                    for (int idx : my_tracks) if (idx != keep) tracks[idx] = 0;
                }
            }
        }
    }

    bool route(bool use_random_seed = true, int seed = 0, mt19937& rng = *(new mt19937(0))) {
        if (use_random_seed) {
            rng.seed(seed);
        }
        
        int top_row_y = num_tracks + 1;
        int col = 0;
        int mid = num_tracks / 2;

        set<pair<int, int>> bad_pairs;
        for (const auto& c : constraints) 
            bad_pairs.insert({min(c.from_net, c.to_net), max(c.from_net, c.to_net)});

        auto is_conflict = [&](int n1, int n2) {
            if (n1 <= 0 || n2 <= 0 || n1 == n2) return false;
            return bad_pairs.count({min(n1, n2), max(n1, n2)}) > 0;
        };

        while (true) {
            bool has_pins = (col < (int)top_pins.size() || col < (int)bottom_pins.size());
            bool has_active_tracks = false;
            for (int i = 1; i <= num_tracks; ++i) if (tracks[i] > 0) has_active_tracks = true;

            if (!has_pins && !has_active_tracks) break;

            int T = (col < (int)top_pins.size()) ? top_pins[col] : 0;
            int B = (col < (int)bottom_pins.size()) ? bottom_pins[col] : 0;
            vector<bool> v_occupied(num_tracks + 2, false);

            // Process top pin
            if (T > 0) {
                bool connected = false;
                
                // Priority 1: Reuse existing track (no via cost)
                for (int i = mid; i <= num_tracks; ++i) {
                    if (tracks[i] == T && check_v(i, top_row_y, T, v_occupied)) {
                        if (!is_conflict(T, tracks[i-1]) && !is_conflict(T, tracks[i+1])) {
                            add_v(col, i, top_row_y, T, v_occupied);
                            connected = true;
                            break;
                        }
                    }
                }
                for (int i = mid - 1; i >= 1 && !connected; --i) {
                    if (tracks[i] == T && check_v(i, top_row_y, T, v_occupied)) {
                        if (!is_conflict(T, tracks[i-1]) && !is_conflict(T, tracks[i+1])) {
                            add_v(col, i, top_row_y, T, v_occupied);
                            connected = true;
                        }
                    }
                }
                
                // Priority 2: Find empty track preferring middle
                if (!connected) {
                    vector<pair<int, int>> candidates; // (priority, idx)
                    
                    for (int i = 1; i <= num_tracks; ++i) {
                        if (tracks[i] != 0) continue;
                        if (!check_v(i, top_row_y, T, v_occupied)) continue;
                        
                        int priority = abs(i - mid);
                        
                        // Higher priority for tracks without conflicts
                        if (is_conflict(T, tracks[i-1]) || is_conflict(T, tracks[i+1])) {
                            priority += 1000;
                        }
                        
                        candidates.push_back({priority, i});
                    }
                    
                    if (!candidates.empty()) {
                        sort(candidates.begin(), candidates.end());
                        int best = candidates[0].second;
                        tracks[best] = T;
                        add_v(col, best, top_row_y, T, v_occupied);
                        connected = true;
                    }
                }
                
                // Priority 3: Allow conflicts (fallback)
                if (!connected) {
                    for (int i = 1; i <= num_tracks; ++i) {
                        if ((tracks[i] == T || tracks[i] == 0) && check_v(i, top_row_y, T, v_occupied)) {
                            tracks[i] = T;
                            add_v(col, i, top_row_y, T, v_occupied);
                            connected = true;
                            break;
                        }
                    }
                }
                
                if (!connected) return false;
            }

            // Process bottom pin
            if (B > 0) {
                bool connected = false;
                
                for (int i = mid + 1; i >= 1; --i) {
                    if (tracks[i] == B && check_v(0, i, B, v_occupied)) {
                        if (!is_conflict(B, tracks[i-1]) && !is_conflict(B, tracks[i+1])) {
                            add_v(col, 0, i, B, v_occupied);
                            connected = true;
                            break;
                        }
                    }
                }
                for (int i = mid + 2; i <= num_tracks && !connected; ++i) {
                    if (tracks[i] == B && check_v(0, i, B, v_occupied)) {
                        if (!is_conflict(B, tracks[i-1]) && !is_conflict(B, tracks[i+1])) {
                            add_v(col, 0, i, B, v_occupied);
                            connected = true;
                        }
                    }
                }
                
                if (!connected) {
                    vector<pair<int, int>> candidates;
                    for (int i = 1; i <= num_tracks; ++i) {
                        if (tracks[i] != 0) continue;
                        if (!check_v(0, i, B, v_occupied)) continue;
                        
                        int priority = abs(i - mid);
                        if (is_conflict(B, tracks[i-1]) || is_conflict(B, tracks[i+1])) {
                            priority += 1000;
                        }
                        
                        candidates.push_back({priority, i});
                    }
                    
                    if (!candidates.empty()) {
                        sort(candidates.begin(), candidates.end());
                        int best = candidates[0].second;
                        tracks[best] = B;
                        add_v(col, 0, best, B, v_occupied);
                        connected = true;
                    }
                }
                
                if (!connected) {
                    for (int i = 1; i <= num_tracks; ++i) {
                        if ((tracks[i] == B || tracks[i] == 0) && check_v(0, i, B, v_occupied)) {
                            tracks[i] = B;
                            add_v(col, 0, i, B, v_occupied);
                            connected = true;
                            break;
                        }
                    }
                }
                
                if (!connected) return false;
            }

            // Collapse with coupling awareness
            collapseTracksWithCouplingAware(col, v_occupied, bad_pairs);

            // Extend horizontally
            for (int i = 1; i <= num_tracks; ++i) {
                if (tracks[i] > 0) nets[tracks[i]].segments.push_back({'H', col, i, col + 1, i});
            }
            
            col++;
        }
        
        return true;
    }

    double calculateCost() {
        double total_length = 0;
        int total_vias = 0;
        int max_col = 0;

        for (const auto& pair : nets) {
            for (const auto& seg : pair.second.segments) {
                if (seg.type == 'H') {
                    total_length += abs(seg.x2 - seg.x1);
                    max_col = max(max_col, max(seg.x1, seg.x2));
                } else if (seg.type == 'V') {
                    total_length += abs(seg.y2 - seg.y1);
                    total_vias++;
                }
            }
        }

        int coupling_length = 0;
        set<pair<int, int>> bad_pairs;
        for (const auto& c : constraints) 
            bad_pairs.insert({min(c.from_net, c.to_net), max(c.from_net, c.to_net)});

        vector<vector<int>> grid(max_col + 1, vector<int>(num_tracks + 2, 0));
        for (const auto& pair : nets) {
            int n = pair.first;
            for (const auto& seg : pair.second.segments) {
                if (seg.type == 'H') {
                    for (int c = seg.x1; c < seg.x2; ++c) grid[c][seg.y1] = n;
                }
            }
        }

        for (int c = 0; c < max_col; ++c) {
            for (int t = 1; t < num_tracks; ++t) {
                int n1 = grid[c][t];
                int n2 = grid[c][t+1];
                if (n1 > 0 && n2 > 0 && n1 != n2) {
                    if (bad_pairs.count({min(n1, n2), max(n1, n2)})) coupling_length++;
                }
            }
        }

        return alpha * num_tracks + beta * total_length + gamma * total_vias + delta * coupling_length;
    }

    void mergeAndWriteOutput(const string& filename) {
        ofstream fout(filename);
        if (!fout.is_open()) return;

        for (auto& pair : nets) {
            int net_id = pair.first;
            if (net_id == 0 || pair.second.segments.empty()) continue;
            
            fout << ".begin " << net_id << "\n";
            
            vector<Segment> h_segs;
            for (const auto& seg : pair.second.segments) {
                if (seg.type == 'V') fout << ".V " << seg.x1 << " " << seg.y1 << " " << seg.y2 << "\n";
                else h_segs.push_back(seg);
            }

            sort(h_segs.begin(), h_segs.end(), [](const Segment& a, const Segment& b){
                if (a.y1 != b.y1) return a.y1 < b.y1;
                return a.x1 < b.x1;
            });

            vector<Segment> merged_h;
            for (const auto& s : h_segs) {
                if (merged_h.empty()) merged_h.push_back(s);
                else {
                    auto& last = merged_h.back();
                    if (last.y1 == s.y1 && last.x2 == s.x1) last.x2 = s.x2;
                    else merged_h.push_back(s);
                }
            }

            for (const auto& s : merged_h) fout << ".H " << s.x1 << " " << s.y1 << " " << s.x2 << "\n";
            fout << ".end\n";
        }
        fout.close();
    }
};

int main(int argc, char* argv[]) {
    if (argc < 3) {
        cerr << "Usage: " << argv[0] << " <input_file> <output_file>\n";
        return 1;
    }

    vector<string> file_lines;
    ifstream fin(argv[1]);
    string line;
    while(getline(fin, line)) file_lines.push_back(line);
    fin.close();

    auto start_time = chrono::high_resolution_clock::now();

    int best_tracks = -1;
    double min_cost = 1e15;
    int best_seed = 0;

    int max_search_tracks = 33;
    int time_limit = 280;

    cout << "🚀 [V3: 耦合感知 + 智慧種子] 啟動！\n";
    cout << "    策略：pin位置種子 + 耦合成本評估 + 轉折優化\n\n";

    mt19937 rng(0);

    // Generate smart seeds
    ChannelRouter init_router(20);
    init_router.parseInput(file_lines);
    
    for (int tracks = 25; tracks <= max_search_tracks; ++tracks) {
        int seeds_to_try = (tracks <= 28) ? 15000 : 5000;
        
        for (int seed = 1; seed <= seeds_to_try; ++seed) {
            auto now = chrono::high_resolution_clock::now();
            int elapsed = chrono::duration_cast<chrono::seconds>(now - start_time).count();
            
            if (elapsed > time_limit * 0.75) goto PHASE2;

            ChannelRouter router(tracks);
            router.parseInput(file_lines);
            
            if (router.route(true, seed, rng)) {
                double cost = router.calculateCost();
                
                if (cost < min_cost) {
                    min_cost = cost;
                    best_tracks = tracks;
                    best_seed = seed;
                    
                    cout << "✨ 新紀錄！ T:" << tracks << " S:" << seed 
                         << " C:" << (int)min_cost << "\n";
                    
                    ChannelRouter tmp(best_tracks);
                    tmp.parseInput(file_lines);
                    tmp.route(true, best_seed, rng);
                    tmp.mergeAndWriteOutput(argv[2]);
                }
            }
        }
    }

PHASE2:
    cout << "\n📈 Phase 2深度優化...\n";
    if (best_tracks > 0) {
        for (int seed = best_seed + 1; seed <= best_seed + 100000; ++seed) {
            auto now = chrono::high_resolution_clock::now();
            if (chrono::duration_cast<chrono::seconds>(now - start_time).count() > time_limit) {
                goto END;
            }

            ChannelRouter router(best_tracks);
            router.parseInput(file_lines);
            
            if (router.route(true, seed, rng)) {
                double cost = router.calculateCost();
                
                if (cost < min_cost) {
                    min_cost = cost;
                    best_seed = seed;
                    
                    cout << "✨ C:" << (int)min_cost << "\n";
                    
                    ChannelRouter tmp(best_tracks);
                    tmp.parseInput(file_lines);
                    tmp.route(true, best_seed, rng);
                    tmp.mergeAndWriteOutput(argv[2]);
                }
            }
        }
    }

END:
    auto end_time = chrono::high_resolution_clock::now();
    int elapsed = chrono::duration_cast<chrono::seconds>(end_time - start_time).count();

    cout << "\n✅ 完成！耗時 " << elapsed << "s\n";
    cout << "📊 T:" << best_tracks << " 軌, 成本 " << (int)min_cost << "\n";

    return 0;
}
